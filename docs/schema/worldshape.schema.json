{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kuronami.dev/isekai_api/worldshape.schema.json",
  "title": "Isekai API WorldshapeDescriptor",
  "description": "Body of data/<ns>/isekai/worldshape/<name>.json. See docs/DATAPACK_REFERENCE.md.",
  "type": "object",
  "required": ["dimension"],
  "additionalProperties": false,
  "properties": {
    "dimension": { "$ref": "#/$defs/resourceKey", "description": "Target dimension key." },
    "playable_range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min_y", "max_y"],
      "properties": {
        "min_y": { "type": "integer" },
        "max_y": { "type": "integer" },
        "distribution": { "$ref": "#/$defs/heightDistribution" }
      }
    },
    "surface_anchor": { "$ref": "#/$defs/surfaceAnchor" },
    "ore_strategy": { "$ref": "#/$defs/remapStrategy" },
    "structure_strategy": { "$ref": "#/$defs/remapStrategy" },
    "mob_spawn_strategy": { "$ref": "#/$defs/remapStrategy" },
    "mob_spawn_strategy_by_category": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/remapStrategy" }
    },
    "default_structure_predicate": { "$ref": "#/$defs/spatialPredicate" },
    "structure_predicates": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/spatialPredicate" }
    },
    "applies_to": { "$ref": "#/$defs/biomeSelection" },
    "exclusions": { "$ref": "#/$defs/contentSet" },
    "additions": { "$ref": "#/$defs/contentSet" },
    "atmosphere": { "$ref": "#/$defs/atmosphere" },
    "client_atmosphere": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fog_color": { "type": "integer" },
        "fog_near_distance": { "type": "number" },
        "fog_far_distance": { "type": "number" }
      }
    },
    "content_overrides": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "feature_predicates": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/spatialPredicate" }
        },
        "structure_spawn_overrides": { "type": "array" },
        "block_overrides": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "surface_top": { "type": "object" },
            "default_block": { "type": "object" }
          }
        }
      }
    },
    "priority": { "type": "integer", "default": 100 }
  },
  "$defs": {
    "resourceKey": {
      "type": "string",
      "pattern": "^[a-z0-9_.-]+:[a-z0-9_./-]+$"
    },
    "resourceOrTag": {
      "type": "string",
      "pattern": "^#?([a-z0-9_.-]+:)?[a-z0-9_./-]+$"
    },
    "heightDistribution": {
      "enum": ["uniform", "trapezoid", "triangle", "biased_low", "biased_high"]
    },
    "biomeSelection": {
      "oneOf": [
        { "type": "array", "items": { "$ref": "#/$defs/resourceOrTag" } },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "keys": { "type": "array", "items": { "$ref": "#/$defs/resourceKey" } },
            "tags": { "type": "array", "items": { "$ref": "#/$defs/resourceOrTag" } }
          }
        }
      ]
    },
    "contentSet": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "features": { "type": "array", "items": { "$ref": "#/$defs/resourceOrTag" } },
        "structures": { "type": "array", "items": { "$ref": "#/$defs/resourceOrTag" } },
        "carvers": { "type": "array", "items": { "$ref": "#/$defs/resourceOrTag" } },
        "mob_spawns": { "type": "array" }
      }
    },
    "surfaceAnchor": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "enum": ["isekai:world_surface", "isekai:below_fluid", "isekai:fixed_y"] }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "isekai:below_fluid" } } },
          "then": { "required": ["fluid"], "properties": { "fluid": { "$ref": "#/$defs/resourceKey" } } }
        },
        {
          "if": { "properties": { "type": { "const": "isekai:fixed_y" } } },
          "then": { "required": ["y"], "properties": { "y": { "type": "integer" } } }
        }
      ]
    },
    "remapStrategy": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "enum": [
            "isekai:identity", "isekai:linear", "isekai:inverted",
            "isekai:fixed_range", "isekai:count_scale", "isekai:band_split", "isekai:pipe"
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "isekai:fixed_range" } } },
          "then": {
            "required": ["min", "max"],
            "properties": {
              "min": { "type": "integer" },
              "max": { "type": "integer" },
              "dist": { "$ref": "#/$defs/heightDistribution" }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "isekai:count_scale" } } },
          "then": { "required": ["factor"], "properties": { "factor": { "type": "number", "minimum": 0 } } }
        },
        {
          "if": { "properties": { "type": { "const": "isekai:band_split" } } },
          "then": { "required": ["bands"], "properties": { "bands": { "type": "array" } } }
        },
        {
          "if": { "properties": { "type": { "const": "isekai:pipe" } } },
          "then": {
            "required": ["chain"],
            "properties": { "chain": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/remapStrategy" } } }
          }
        }
      ]
    },
    "spatialPredicate": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "enum": [
            "isekai:y_in_range", "isekai:solid_floor", "isekai:solid_ceiling",
            "isekai:terrain_slope", "isekai:near_block", "isekai:near_biome",
            "isekai:in_fluid", "isekai:always", "isekai:never",
            "isekai:and", "isekai:or", "isekai:not"
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "isekai:y_in_range" } } },
          "then": { "properties": { "min": { "type": "integer" }, "max": { "type": "integer" } } }
        },
        {
          "if": { "properties": { "type": { "const": "isekai:solid_floor" } } },
          "then": { "properties": { "min_clearance": { "type": "integer" } } }
        },
        {
          "if": { "properties": { "type": { "const": "isekai:solid_ceiling" } } },
          "then": { "properties": { "min_clearance": { "type": "integer" } } }
        },
        {
          "if": { "properties": { "type": { "const": "isekai:terrain_slope" } } },
          "then": { "properties": { "min_slope": { "type": "number" }, "max_slope": { "type": "number" } } }
        },
        {
          "if": { "properties": { "type": { "const": "isekai:near_block" } } },
          "then": { "required": ["max_distance"], "properties": { "targets": {}, "max_distance": { "type": "integer" } } }
        },
        {
          "if": { "properties": { "type": { "const": "isekai:near_biome" } } },
          "then": { "required": ["biome", "max_distance"], "properties": { "biome": { "$ref": "#/$defs/resourceKey" }, "max_distance": { "type": "integer" } } }
        },
        {
          "if": { "properties": { "type": { "const": "isekai:in_fluid" } } },
          "then": { "required": ["fluid"], "properties": { "fluid": { "$ref": "#/$defs/resourceKey" } } }
        },
        {
          "if": { "properties": { "type": { "const": "isekai:and" } } },
          "then": { "required": ["all"], "properties": { "all": { "type": "array", "items": { "$ref": "#/$defs/spatialPredicate" } } } }
        },
        {
          "if": { "properties": { "type": { "const": "isekai:or" } } },
          "then": { "required": ["any"], "properties": { "any": { "type": "array", "items": { "$ref": "#/$defs/spatialPredicate" } } } }
        },
        {
          "if": { "properties": { "type": { "const": "isekai:not" } } },
          "then": { "required": ["inner"], "properties": { "inner": { "$ref": "#/$defs/spatialPredicate" } } }
        }
      ]
    },
    "atmosphere": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "has_precipitation": { "type": "boolean" },
        "temperature": { "type": "number" },
        "downfall": { "type": "number" },
        "sky_color": { "type": "integer" },
        "fog_color": { "type": "integer" },
        "water_color": { "type": "integer" },
        "water_fog_color": { "type": "integer" },
        "foliage_color": { "type": "integer" },
        "grass_color": { "type": "integer" },
        "creature_generation_probability": { "type": "number" },
        "mob_spawn_costs": { "type": "object" },
        "effects_extras": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "grass_color_modifier": { "enum": ["none", "dark_forest", "swamp"] },
            "particle": { "type": "object" },
            "ambient_sound": { "$ref": "#/$defs/resourceOrTag" },
            "mood_sound": { "type": "object" },
            "additions_sound": { "type": "object" },
            "music": { "type": "object" }
          }
        }
      }
    }
  }
}
