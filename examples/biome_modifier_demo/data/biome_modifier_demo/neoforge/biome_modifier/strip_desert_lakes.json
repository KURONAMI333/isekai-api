{
  "type": "isekai_api:apply_worldshape",
  "worldshape": {
    "dimension": "minecraft:overworld",
    "playable_range": {
      "min_y": -64,
      "max_y": 320,
      "distribution": "uniform"
    },
    "surface_anchor": { "type": "isekai:world_surface" },
    "ore_strategy":       { "type": "isekai:identity" },
    "structure_strategy": { "type": "isekai:identity" },
    "mob_spawn_strategy": { "type": "isekai:identity" },
    "default_structure_predicate": { "type": "isekai:always" },
    "applies_to": [
      "minecraft:desert"
    ],
    "exclusions": {
      "features": [
        "minecraft:lake_lava_surface"
      ]
    }
  }
}
